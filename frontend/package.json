{
  "name": "frontend",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "build": "webpack",
    "prewatch": "npm ci",
    "watch": "NODE_ENV=development npm run build -- --watch",
    "test": "jest",
    "test:ci": "jest --ci --coverage",
    "prepare": "cd .. && husky frontend/.husky || true"
  },
  "license": "ISC",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/preset-env": "^7.29.0",
    "@vue/test-utils": "^2.4.6",
    "@vue/vue3-jest": "^29.2.6",
    "autoprefixer": "^10.4.27",
    "babel-jest": "^29.7.0",
    "clean-webpack-plugin": "^4.0.0",
    "css-loader": "^7.1.4",
    "cssnano": "^7.1.2",
    "husky": "^9.1.7",
    "jest": "^29.7.0",
    "jest-environment-jsdom": "^29.7.0",
    "lint-staged": "^16.3.2",
    "mini-css-extract-plugin": "^2.10.0",
    "postcss-import": "^16.1.1",
    "postcss-loader": "^8.2.1",
    "postcss-preset-env": "^10.1.0",
    "prettier": "^2.0.5",
    "vue-loader": "^17.4.2",
    "webpack": "^5.105.4",
    "webpack-bundle-tracker": "^3.2.3",
    "webpack-cli": "^6.0.1"
  },
  "dependencies": {
    "@stripe/stripe-js": "^1.11.0",
    "easymde": "^2.20.0",
    "lightense-images": "^1.0.17",
    "mapbox-gl": "^2.15.0",
    "normalize.css": "^8.0.1",
    "vue": "^3.5.29",
    "vue-select": "^4.0.0-beta.6"
  },
  "lint-staged": {
    "{*.js,*.vue}": [
      "prettier --write"
    ]
  },
  "prettier": {
    "printWidth": 120
  },
  "browserslist": [
    "last 2 versions",
    "not dead",
    "not op_mini all",
    "not op_mob > 0",
    "not and_qq > 0",
    "not android > 0"
  ]
}
